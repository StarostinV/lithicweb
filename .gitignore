# =============================================================================
# 3D Annotation Tool - Git Ignore Configuration
# =============================================================================
#
# This file specifies which files and directories Git should ignore.
# Patterns use glob syntax: * matches any characters, ** matches directories.
#
# To check if a file is ignored: git check-ignore -v <filename>
# To see all ignored files: git status --ignored
#
# =============================================================================

# -----------------------------------------------------------------------------
# Dependencies
# -----------------------------------------------------------------------------
# Node.js packages installed via npm. These are restored with `npm install`.

node_modules/

# -----------------------------------------------------------------------------
# Build Output
# -----------------------------------------------------------------------------
# Generated files from webpack build. Recreated with `npm run build`.

dist/

# -----------------------------------------------------------------------------
# Test Coverage
# -----------------------------------------------------------------------------
# Generated by `npm run test:coverage`. Contains HTML reports and lcov data.

coverage/

# -----------------------------------------------------------------------------
# IDE and Editor Files
# -----------------------------------------------------------------------------
# Editor-specific settings and caches. Each developer has their own.

# JetBrains IDEs (WebStorm, IntelliJ)
.idea/

# Visual Studio Code
# Note: .vscode/tasks.json is tracked for shared build tasks
.vscode/*
!.vscode/tasks.json

# macOS Finder metadata
.DS_Store

# Claude Code
CLAUDE.md
.claude/

# -----------------------------------------------------------------------------
# Mesh Data Files
# -----------------------------------------------------------------------------
# PLY files are 3D mesh data that can be large. We ignore them everywhere
# EXCEPT in the tests/fixtures/ directory where they're needed for testing.
#
# To add a test fixture: place it in tests/fixtures/ply/

*.ply
!tests/fixtures/**/*.ply

# MAT files (MATLAB mesh format)
*.mat
!tests/fixtures/**/*.mat

# -----------------------------------------------------------------------------
# Logs and Temporary Files
# -----------------------------------------------------------------------------
# Runtime logs and temporary files that shouldn't be committed.

# Log files
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Runtime data
pids/
*.pid
*.seed
*.pid.lock

# -----------------------------------------------------------------------------
# Environment and Secrets
# -----------------------------------------------------------------------------
# Never commit secrets or environment-specific configuration.

.env
.env.local
.env.*.local
*.pem
credentials.json

# -----------------------------------------------------------------------------
# Archives
# -----------------------------------------------------------------------------
# Compressed files that are typically data exports or downloads.

*.zip
*.tar
*.gz
*.rar
*.7z
